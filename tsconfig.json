{
	"compilerOptions": {
		"module": "nodenext",
        "moduleResolution": "nodenext",
		"target": "es2022",
		"lib": [
			"es2022"
		],
		"types": ["node"],

		"rootDir": "src",
		"outDir": "dist",
        "sourceMap": true,

		"strict": true,
        "noUnusedLocals": true,
        "noImplicitThis": true,
        "noImplicitReturns": true,
        "strictNullChecks": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true
	}
}
